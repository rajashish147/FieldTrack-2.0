# FieldTrack 2.0 Backend — Environment Variables
# Copy this file to .env and fill in all required values before starting the server.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase ───────────────────────────────────────────────────────────────────
# Supabase project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service role key — grants full database access; never expose to clients
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — safe for client-side; used for Supabase JS client initialisation
SUPABASE_ANON_KEY=

# JWT secret — must match the "JWT Secret" in your Supabase project settings
SUPABASE_JWT_SECRET=

# ── Redis ──────────────────────────────────────────────────────────────────────
# Full Redis connection URL (redis:// or rediss:// for TLS)
# Example: redis://127.0.0.1:6379
REDIS_URL=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all origins (dev only).
# Production: https://fieldtrack.meowsician.tech
# Local development: http://localhost:3000
ALLOWED_ORIGINS=

# ── Domains ────────────────────────────────────────────────────────────────────
# Public API domain used by generated docs and infrastructure templates.
# Example: api.fieldtrack.meowsician.tech
API_DOMAIN=

# Public frontend domain (used by infra/docs templates).
# Example: fieldtrack.meowsician.tech
FRONTEND_DOMAIN=

# ── Observability ──────────────────────────────────────────────────────────────
# Tempo OTLP HTTP endpoint for distributed tracing (optional; tracing disabled if unset)
# Example: http://localhost:4318
TEMPO_ENDPOINT=

# Prometheus scrape endpoint protection token.
# If set, GET /metrics requires the header: x-metrics-token: <token>
# Leave empty to allow unauthenticated scraping (development only).
METRICS_SCRAPE_TOKEN=

# ── Worker Safety Limits (optional — defaults shown as comments) ───────────────
# MAX_QUEUE_DEPTH=1000
# MAX_POINTS_PER_SESSION=50000
# MAX_SESSION_DURATION_HOURS=168
# WORKER_CONCURRENCY=1
