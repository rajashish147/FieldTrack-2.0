# Root .dockerignore — build context is the repo root

# Version control
.git
.gitignore

# All node_modules (Docker installs fresh)
node_modules

# Build artefacts (Docker regenerates these)
dist
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example

# IDE / OS
.idea
.vscode
*.swp
.DS_Store
Thumbs.db

# Docs and CI config (not needed in image)
docs
*.md
.github

# Infra, supabase and other repo artefacts
infra
supabase
codeql-db
results
apps
packages
