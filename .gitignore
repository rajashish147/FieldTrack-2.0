# ============================================
# .gitignore for FieldTrack API
# ============================================

# Deployment history (VPS-side file, never committed)
.deploy_history
.last_deploy
# Fallback deploy state when /var/lib/fieldtrack is not writable (slot, lock)
.fieldtrack/

# ----------------
# Dependencies
# ----------------
node_modules/
apps/*/node_modules/
packages/*/node_modules/
/.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Optional npm cache directory
.npm

# ----------------
# Environment Files
# ----------------
.env
.env.*
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ----------------
# Build Output
# ----------------
dist/
build/
.next/
out/

# ----------------
# Testing
# ----------------
coverage/
*.test.ts.snap
*.test.tsx.snap
.nyc_output/

# ----------------
# TypeScript
# ----------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# ----------------
# Logs
# ----------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------
# OS Files
# ----------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----------------
# CodeQL
# ----------------
codeql-db/
results/
*.sarif

# ----------------
# Supabase local dev
# ----------------
.supabase/

# ----------------
# IDE / Editors
# ----------------
# Allow shared workspace settings and extension recommendations;
# ignore personal/machine-specific files (launch.json, mcp.json, tasks.json).
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.kiro/
.local

# ----------------
# Temporary Files
# ----------------
*.tmp
*.temp
.cache/

# ----------------
# Optional Caches
# ----------------
.eslintcache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ----------------
# Deployment
# ----------------
.vercel

# ----------------
# Misc
# ----------------
*.pem
.repl_history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Storybook
storybook-static/

# Sentry
.sentryclirc

#Skills
.github/skills/

#old migration files
supabase/old-migration/
