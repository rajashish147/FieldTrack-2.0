# FieldTrack 2.0 Backend — Environment Variables
# Copy this file to .env and fill in the values

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Redis (BullMQ durable queue) ───────────────────────────────────────────────
REDIS_URL=redis://your-redis-host:6379

# ── CORS (comma-separated origins, leave empty to block all cross-origin) ─────
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Worker Safety Limits (optional, defaults shown) ───────────────────────────
# MAX_QUEUE_DEPTH=1000
# MAX_POINTS_PER_SESSION=50000
# MAX_SESSION_DURATION_HOURS=168
